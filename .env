# ==============================================================================
# fyntrac-py-model — Environment Variables
# ==============================================================================

# ── Service ──────────────────────────────────────────────────────────────
SERVICE_PORT=8090
SERVICE_HOST=0.0.0.0

# ── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=root
MONGODB_PASSWORD=R3s3rv#313
MONGODB_AUTH_DATABASE=admin
MONGODB_DEFAULT_DATABASE=master

# ── ZITADEL / JWT ────────────────────────────────────────────────────────
ZITADEL_ISSUER_URI=https://your-zitadel-instance.zitadel.cloud
ZITADEL_PROJECT_ID=your-project-id

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3030

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Pulsar — Downstream producers (mirror Java model service) ─────────────
# Topic consumed by Java aggregation service
PULSAR_AGGREGATION_TOPIC=persistent://public/default/fyntrac-aggregate-execution
# Topic consumed by Java GL service
PULSAR_GL_STAGING_TOPIC=persistent://public/default/fyntrac-book-gl-staging

